{
    "apiVersion": 3,
    "name": "zentra/footer",
    "title": "Zentra Footer",
    "category": "theme",
    "description": "Reusable Zentra footer block with fully customizable columns and link lists.",
    "attributes": {
        "logo_url": {
            "type": "string",
            "default": "/wp-content/themes/child-zentra/assets/images/logo.webp"
        },
        "tagline": {
            "type": "string",
            "default": "Secure Banking for a Digital World"
        },
        "col1_title": {
            "type": "string",
            "default": "Product"
        },
        "col1_links": {
            "type": "array",
            "default": [
                {
                    "label": "Features",
                    "url": "#"
                },
                {
                    "label": "Pricing",
                    "url": "#"
                },
                {
                    "label": "Updates",
                    "url": "#"
                },
                {
                    "label": "Security",
                    "url": "#"
                }
            ]
        },
        "col2_title": {
            "type": "string",
            "default": "Company"
        },
        "col2_links": {
            "type": "array",
            "default": [
                {
                    "label": "About Us",
                    "url": "#"
                },
                {
                    "label": "Careers",
                    "url": "#"
                },
                {
                    "label": "Press",
                    "url": "#"
                },
                {
                    "label": "Partners",
                    "url": "#"
                }
            ]
        },
        "col3_title": {
            "type": "string",
