        "col4_links": {
            "type": "array",
            "default": [
                {
                    "label": "Terms & Conditions",
                    "url": "#"
                },
                {
                    "label": "Privacy Policy",
                    "url": "#"
                },
                {
                    "label": "Compliance",
                    "url": "#"
                },
                {
                    "label": "Licenses",
                    "url": "#"
                }
